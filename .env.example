# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID офиса приёмки Wildberries (по умолчанию — нужно заменить)
# Номер можно найти в личном кабинете WB → Поставки → Офисы приёмки
DESTINATION_OFFICE_ID=0

# Интервал опроса новых заказов (в секундах)
POLL_INTERVAL=30

# Директория для хранения данных
DATA_DIR=data